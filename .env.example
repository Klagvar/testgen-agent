# ─── LLM Configuration ───
# API key for the LLM provider (OpenAI, OpenRouter, Groq, etc.)
TESTGEN_API_KEY=sk-your-key-here

# API base URL (default: https://api.openai.com/v1)
# For Ollama: http://localhost:11434/v1
# For OpenRouter: https://openrouter.ai/api/v1
# TESTGEN_API_URL=https://api.openai.com/v1

# Model name (default: gpt-4o-mini)
# TESTGEN_MODEL=gpt-4o-mini

# ─── GitHub Integration (for PR comments) ───
# Personal access token or fine-grained token with "Pull Requests: Read and write"
# In GitHub Actions this is provided automatically as ${{ secrets.GITHUB_TOKEN }}
GITHUB_TOKEN=github_pat_your-token-here

# Repository in "owner/repo" format
# In GitHub Actions this is ${{ github.repository }}
GITHUB_REPOSITORY=your-username/your-repo

# Pull request number to comment on
# In GitHub Actions: ${{ github.event.pull_request.number }}
TESTGEN_PR_NUMBER=1
